{
  "manifest_version": 3,
  "name": "ProjectHub",
  "version": "0.2.0",
  "description": "A project prioritization and organization workspace using RICE frameworks and MoSCoW filters.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
